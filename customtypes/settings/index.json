{
  "format": "custom",
  "id": "settings",
  "label": "Settings",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "site_title": {
        "type": "Text",
        "config": {
          "label": "Site Title",
          "placeholder": ""
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": ""
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      }
    },
    "Footer": {
      "logo": {
        "type": "Image",
        "config": {
          "label": "Logo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "columns": {
        "type": "Group",
        "config": {
          "label": "Columns",
          "repeat": true,
          "fields": {
            "title": {
              "type": "Text",
              "config": {
                "label": "Title",
                "placeholder": ""
              }
            },
            "column": {
              "type": "StructuredText",
              "config": {
                "label": "Text",
                "placeholder": "",
                "allowTargetBlank": true,
                "multi": "paragraph,heading3,heading4,heading5,heading6,strong,em,hyperlink,list-item,o-list-item,rtl"
              }
            }
          }
        }
      },
      "bottom_link": {
        "type": "Link",
        "config": {
          "label": "Bottom Link",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": true
        }
      }
    },
    "Navigation": {
      "navbar_links": {
        "type": "Link",
        "config": {
          "label": "Navbar Links",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": true
        }
      },
      "column_1": {
        "type": "Link",
        "config": {
          "label": "Column 1",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": true
        }
      },
      "column_2": {
        "type": "Link",
        "config": {
          "label": "Column 2",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": true
        }
      }
    }
  }
}
